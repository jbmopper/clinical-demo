# Copy to .env (which is gitignored) and fill in.
# Real keys NEVER live in this file.

# --- LLM providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- Observability ---
# Use Langfuse Cloud (https://cloud.langfuse.com) or self-hosted (e.g. on GCP).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

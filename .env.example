# Copy to .env (which is gitignored) and fill in.
# Real keys NEVER live in this file.

# --- LLM providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- NLM terminology APIs (VSAC / RxNorm / UMLS) ---
# Single UTS API key (https://uts.nlm.nih.gov/uts/profile) used as the
# Basic-auth password against all three NLM REST surfaces. Required
# for live VSAC probing and future terminology-backed binding. The
# current matcher alias path does not need it. See PLAN.md §12 D-69.
UMLS_API_KEY=

# Reserved terminology binding switch. Only "alias" is wired today;
# future API-backed strategies should reject/record their behavior
# explicitly instead of silently changing matcher semantics.
BINDING_STRATEGY=alias

# Where the terminology cache writes resolved bindings (VSAC value-set
# expansions today; RxNorm/UMLS results when those clients land).
# Lives under data/cache/ (gitignored) so eval re-runs don't pay the
# NLM round-trip on every pair. Override for tests or to share a
# cache between checkouts.
TERMINOLOGY_CACHE_DIR=data/cache/terminology

# --- Observability ---
# Use Langfuse Cloud (https://cloud.langfuse.com or https://us.cloud.langfuse.com)
# or self-hosted. Tracing is on iff BOTH keys are set; otherwise the
# observability shim is a no-op (CI / fresh checkouts work without keys).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST is the canonical SDK env var; LANGFUSE_BASE_URL is also
# accepted as an alias for ergonomics.
LANGFUSE_HOST=https://cloud.langfuse.com

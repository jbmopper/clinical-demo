# Copy to .env (which is gitignored) and fill in.
# Real keys NEVER live in this file.

# --- LLM providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- Observability ---
# Use Langfuse Cloud (https://cloud.langfuse.com or https://us.cloud.langfuse.com)
# or self-hosted. Tracing is on iff BOTH keys are set; otherwise the
# observability shim is a no-op (CI / fresh checkouts work without keys).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST is the canonical SDK env var; LANGFUSE_BASE_URL is also
# accepted as an alias for ergonomics.
LANGFUSE_HOST=https://cloud.langfuse.com
